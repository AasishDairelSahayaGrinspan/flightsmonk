# OAuth2 Client Credentials (required for new accounts since March 2025)
# Get these from https://opensky-network.org - Account Settings - API Client
OPENSKY_CLIENT_ID=your-client-id
OPENSKY_CLIENT_SECRET=your-client-secret

# Server port (Azure sets this automatically in production)
PORT=3000

# Environment
NODE_ENV=development

# India bounding box (default region to fetch flights from)
INDIA_LAMIN=6.5
INDIA_LOMIN=68.0
INDIA_LAMAX=35.5
INDIA_LOMAX=97.5
